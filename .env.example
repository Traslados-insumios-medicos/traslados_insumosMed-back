# Base de datos PostgreSQL
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/medlogix_db"
# URL directa (sin pooler) para migraciones Prisma
DIRECT_URL="postgresql://USER:PASSWORD@localhost:5432/medlogix_db"

# JWT
JWT_SECRET="tu_secreto_jwt_aqui"
JWT_EXPIRES_IN="7d"

# Servidor
PORT=3000
NODE_ENV=development

# Cloudinary (para fotos de entregas y hojas de ruta)
CLOUDINARY_CLOUD_NAME="tu_cloud_name"
CLOUDINARY_API_KEY="tu_api_key"
CLOUDINARY_API_SECRET="tu_api_secret"

# CORS - origen del frontend
FRONTEND_URL="http://localhost:5173"
# Producción (si necesitas múltiples orígenes, separa por coma):
# FRONTEND_URL="https://tu-frontend.onrender.com,https://www.tudominio.com"
# WebSocket (reservado para tracking en tiempo real con Mapbox)
# WS_PORT=3001

# Webhooks salientes (opcional)
# URLs destino separadas por coma
WEBHOOK_URLS=""
# Clave para firma HMAC SHA256 (header x-webhook-signature)
WEBHOOK_SECRET=""
# Timeout por intento en ms
WEBHOOK_TIMEOUT_MS=5000
# Reintentos por URL
WEBHOOK_RETRIES=3
