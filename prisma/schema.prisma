generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Cliente {
  id                  String        @id @default(cuid())
  nombre              String
  ruc                 String        @unique
  direccion           String
  telefonoContacto    String?
  emailContacto       String?
  activo              Boolean       @default(true)
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt
  clientePrincipalId  String?
  tipo                TipoCliente   @default(SECUNDARIO)
  lat                 Float?
  lng                 Float?
  clientePrincipal    Cliente?      @relation("ClienteJerarquia", fields: [clientePrincipalId], references: [id])
  clientesSecundarios Cliente[]     @relation("ClienteJerarquia")
  guias               GuiaEntrega[]
  stops               Stop[]
  usuarios            Usuario[]
}

model Usuario {
  id                 String    @id @default(cuid())
  nombre             String
  cedula             String?   @unique
  email              String    @unique
  password           String
  rol                Rol
  activo             Boolean   @default(true)
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
  clienteId          String?
  mustChangePassword Boolean   @default(false)
  activeSessionToken String?   @unique
  resetToken         String?   @unique
  resetTokenExpiry   DateTime?
  celular            String?   @unique
  rutas              Ruta[]
  cliente            Cliente?  @relation(fields: [clienteId], references: [id])
}

model Ruta {
  id                String                  @id @default(cuid())
  fecha             String
  estado            EstadoRuta              @default(PENDIENTE)
  createdAt         DateTime                @default(now())
  updatedAt         DateTime                @updatedAt
  choferId          String
  seguimientoChofer EstadoSeguimientoChofer @default(NINGUNO)
  fotos             Foto[]
  guias             GuiaEntrega[]
  chofer            Usuario                 @relation(fields: [choferId], references: [id])
  stops             Stop[]
}

model Stop {
  id        String        @id @default(cuid())
  orden     Int
  direccion String
  lat       Float
  lng       Float
  notas     String?
  createdAt DateTime      @default(now())
  rutaId    String
  clienteId String
  guias     GuiaEntrega[]
  cliente   Cliente       @relation(fields: [clienteId], references: [id])
  ruta      Ruta          @relation(fields: [rutaId], references: [id], onDelete: Cascade)
}

model GuiaEntrega {
  id             String     @id @default(cuid())
  numeroGuia     String     @unique
  descripcion    String
  estado         EstadoGuia @default(PENDIENTE)
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt
  receptorNombre String?
  horaLlegada    String?
  horaSalida     String?
  temperatura    String?
  observaciones  String?
  clienteId      String
  rutaId         String
  stopId         String
  fotos          Foto[]
  cliente        Cliente    @relation(fields: [clienteId], references: [id])
  ruta           Ruta       @relation(fields: [rutaId], references: [id], onDelete: Cascade)
  stop           Stop       @relation(fields: [stopId], references: [id])
  novedades      Novedad[]
}

model Foto {
  id         String       @id @default(cuid())
  tipo       TipoFoto
  urlPreview String
  publicId   String?
  createdAt  DateTime     @default(now())
  guiaId     String?
  rutaId     String?
  guia       GuiaEntrega? @relation(fields: [guiaId], references: [id], onDelete: Cascade)
  ruta       Ruta?        @relation(fields: [rutaId], references: [id], onDelete: Cascade)
}

model Novedad {
  id           String               @id @default(cuid())
  tipo         TipoNovedad
  descripcion  String
  createdAt    DateTime             @default(now())
  guiaId       String
  guia         GuiaEntrega          @relation(fields: [guiaId], references: [id], onDelete: Cascade)
  seguimientos SeguimientoNovedad[]
}

model SeguimientoNovedad {
  id        String   @id @default(cuid())
  nota      String
  createdAt DateTime @default(now())
  novedadId String
  novedad   Novedad  @relation(fields: [novedadId], references: [id], onDelete: Cascade)
}

model ruta_seguimiento_logs {
  id                 String   @id
  ruta_id            String
  chofer_id          String
  seguimiento_chofer String
  created_at         DateTime @default(now()) @db.Timestamptz(6)

  @@index([ruta_id, created_at(sort: Desc)], map: "idx_ruta_seguimiento_logs_ruta_id_created_at")
}

enum Rol {
  ADMIN
  CHOFER
  CLIENTE
}

enum EstadoRuta {
  PENDIENTE
  EN_CURSO
  COMPLETADA
  CANCELADA
}

enum EstadoGuia {
  PENDIENTE
  ENTREGADO
  INCIDENCIA
}

enum TipoNovedad {
  DIRECCION_INCORRECTA
  CLIENTE_AUSENTE
  MERCADERIA_DANADA
  OTRO
}

enum TipoFoto {
  GUIA
  HOJA_RUTA
}

enum TipoCliente {
  PRINCIPAL
  SECUNDARIO
}

enum EstadoSeguimientoChofer {
  NINGUNO
  EN_CAMINO
  CERCA_DESTINO
}
