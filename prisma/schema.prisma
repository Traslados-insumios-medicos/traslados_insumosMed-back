generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Cliente {
  id               String        @id @default(cuid())
  nombre           String
  ruc              String        @unique
  direccion        String
  telefonoContacto String?
  emailContacto    String?
  tipo             TipoCliente   @default(SECUNDARIO)
  clientePrincipalId String?
  activo           Boolean       @default(true)
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
  clientePrincipal Cliente?      @relation("JerarquiaCliente", fields: [clientePrincipalId], references: [id], onDelete: SetNull)
  clientesSecundarios Cliente[]  @relation("JerarquiaCliente")
  guias            GuiaEntrega[]
  stops            Stop[]
  usuarios         Usuario[]
}

model Usuario {
  id                 String   @id @default(cuid())
  nombre             String
  cedula             String?  @unique
  email              String   @unique
  password           String
  rol                Rol
  activo             Boolean  @default(true)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  clienteId          String?
  mustChangePassword Boolean  @default(false)
  rutas              Ruta[]
  cliente            Cliente? @relation(fields: [clienteId], references: [id])
}

model Ruta {
  id        String        @id @default(cuid())
  fecha     String
  estado    EstadoRuta    @default(PENDIENTE)
  seguimientoChofer EstadoSeguimientoChofer @default(NINGUNO)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  choferId  String
  fotos     Foto[]
  guias     GuiaEntrega[]
  chofer    Usuario       @relation(fields: [choferId], references: [id])
  stops     Stop[]
}

model Stop {
  id        String        @id @default(cuid())
  orden     Int
  direccion String
  lat       Float
  lng       Float
  notas     String?
  createdAt DateTime      @default(now())
  rutaId    String
  clienteId String
  guias     GuiaEntrega[]
  cliente   Cliente       @relation(fields: [clienteId], references: [id])
  ruta      Ruta          @relation(fields: [rutaId], references: [id], onDelete: Cascade)
}

model GuiaEntrega {
  id             String     @id @default(cuid())
  numeroGuia     String     @unique
  descripcion    String
  estado         EstadoGuia @default(PENDIENTE)
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt
  receptorNombre String?
  horaLlegada    String?
  horaSalida     String?
  temperatura    String?
  observaciones  String?
  clienteId      String
  rutaId         String
  stopId         String
  fotos          Foto[]
  cliente        Cliente    @relation(fields: [clienteId], references: [id])
  ruta           Ruta       @relation(fields: [rutaId], references: [id], onDelete: Cascade)
  stop           Stop       @relation(fields: [stopId], references: [id])
  novedades      Novedad[]
}

model Foto {
  id         String       @id @default(cuid())
  tipo       TipoFoto
  urlPreview String
  publicId   String?
  createdAt  DateTime     @default(now())
  guiaId     String?
  rutaId     String?
  guia       GuiaEntrega? @relation(fields: [guiaId], references: [id], onDelete: Cascade)
  ruta       Ruta?        @relation(fields: [rutaId], references: [id], onDelete: Cascade)
}

model Novedad {
  id           String               @id @default(cuid())
  tipo         TipoNovedad
  descripcion  String
  createdAt    DateTime             @default(now())
  guiaId       String
  guia         GuiaEntrega          @relation(fields: [guiaId], references: [id], onDelete: Cascade)
  seguimientos SeguimientoNovedad[]
}

model SeguimientoNovedad {
  id        String   @id @default(cuid())
  nota      String
  createdAt DateTime @default(now())
  novedadId String
  novedad   Novedad  @relation(fields: [novedadId], references: [id], onDelete: Cascade)
}

enum Rol {
  ADMIN
  CHOFER
  CLIENTE
}

enum EstadoRuta {
  PENDIENTE
  EN_CURSO
  COMPLETADA
  CANCELADA
}

enum EstadoSeguimientoChofer {
  NINGUNO
  EN_CAMINO
  EN_TRAFICO
  CERCA_DESTINO
}

enum EstadoGuia {
  PENDIENTE
  ENTREGADO
  INCIDENCIA
}

enum TipoNovedad {
  DIRECCION_INCORRECTA
  CLIENTE_AUSENTE
  MERCADERIA_DANADA
  OTRO
}

enum TipoFoto {
  GUIA
  HOJA_RUTA
}

enum TipoCliente {
  PRINCIPAL
  SECUNDARIO
}
